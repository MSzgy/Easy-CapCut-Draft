meta {
  name: image_api_gemini_format
  type: http
  seq: 5
}

post {
  url: https://cpa.mosuyang.org/v1beta/models/gemini-3-pro-image-preview:generateContent
  body: json
  auth: bearer
}

headers {
  Connection: keep-alive
}

auth:bearer {
  token: test
}

body:json {
  {
    "contents": [
      {
        "role": "model",
        "parts": [
          {
             "text":  "你是一个专业的视频封面设计AI助手。你的任务是生成适合抖音平台的高清晰度视频封面图片。要求 1. 符合抖音平台的视觉风格：鲜艳、吸引眼球、高对比度. 2. 符合用户要求. 3. 符合平台内容审核标准"
          }
        ]
      },
      {
        "role": "user",
        "parts": [
          {
            "text": "一场淋漓尽致的篮球赛"
          }
        ]
      }
    ],
    "generationConfig": {
      "responseModalities": [
        "Image"
      ]
  //     "imageConfig": {
  //       "aspectRatio": "16:9",
  //       "imageSize": "1K"
  //     }
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
